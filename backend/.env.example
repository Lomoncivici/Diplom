ENVIRONMENT=development
DATABASE_URL=postgresql+psycopg://platform_user:platform_password@db:5432/loadtest_platform
JWT_SECRET_KEY=replace_with_a_long_random_secret_at_least_32_characters
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120
ACCESS_TOKEN_COOKIE_NAME=access_token
JWT_COOKIE_SECURE=false
JWT_COOKIE_SAMESITE=lax
CORS_ORIGINS=http://localhost:5173,http://localhost:8080
ALLOW_PRIVATE_TARGET_HOSTS=
AUTH_RATE_LIMIT_WINDOW_MINUTES=15
AUTH_RATE_LIMIT_MAX_FAILURES=5
AUTH_RATE_LIMIT_LOCK_MINUTES=15
